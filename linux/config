# Basic
CONFIG_64BIT=y                 # 64-bit kernel
CONFIG_BLK_DEV_INITRD=y        # initramfs support
CONFIG_BINFMT_ELF=y            # run elf binaries
CONFIG_MODULES=y               # load kernel modules
CONFIG_HYPERVISOR_GUEST=y      # virtualization
CONFIG_PARAVIRT=y              # paravirtualization
CONFIG_WERROR=n                # do not treat warnings as errors
CONFIG_LOCALVERSION_AUTO=n     # do not add "-dirty" to version

# Output
CONFIG_TTY=y                   # TTY support
CONFIG_SERIAL_8250=y           # 8250 serial port support
CONFIG_SERIAL_8250_CONSOLE=y   # Console on serial port
CONFIG_PRINTK=y                # printk support
CONFIG_PRINTK_TIME=y           # printk with timestamp

# File systems
CONFIG_PROC_FS=y               # /proc
CONFIG_SYSFS=y                 # /sys
CONFIG_DEBUG_FS=y              # /sys/kernel/debug
CONFIG_DEVTMPFS=y              # /dev
CONFIG_DEVTMPFS_MOUNT=y        # /dev auto mount

# CPU and power management
CONFIG_ACPI=y                  # ACPI support
CONFIG_ACPI_PROCESSOR=y        # ACPI processor support
CONFIG_ACPI_HOTPLUG_CPU=y      # ACPI CPU hotplug support
CONFIG_CPU_FREQ=y              # Frequency scaling
CONFIG_HOTPLUG_CPU=y           # CPU hotplug support
CONFIG_PM_SLEEP=y              # PM sleep support
CONFIG_PM_SLEEP_SMP=y          # PM sleep SMP support
CONFIG_SUSPEND=y               # Suspend support
CONFIG_FREEZER=y               # Freezer support

# Scheduler
CONFIG_SMP=y                   # SMP support
CONFIG_NUMA=y                  # NUMA support
CONFIG_SCHED_CORE=y            # Core scheduler
CONFIG_SCHED_SMT=y             # SMT scheduler
CONFIG_SCHED_CLUSTER=y         # Cluster scheduler
CONFIG_SCHED_MC=y              # MC scheduler
CONFIG_CGROUPS=y               # cgroups support
CONFIG_CGROUP_SCHED=y          # cgroup scheduler support
CONFIG_FAIR_GROUP_SCHED=y      # CFS
CONFIG_CFS_BANDWIDTH=y         # CFS bandwidth control
CONFIG_RT_GROUP_SCHED=y        # RT
CONFIG_HIGH_RES_TIMERS=y       # High resolution timers
CONFIG_SCHED_DEBUG=y
CONFIG_HZ_1000=y
CONFIG_NO_HZ_COMMON=n
CONFIG_NO_HZ_IDLE=n
CONFIG_NO_HZ=n
CONFIG_NO_HZ_FULL=n
CONFIG_RCU_NOCB_CPU=n
# CONFIG_NO_HZ=y
# CONFIG_NO_HZ_FULL=y
# CONFIG_RCU_NOCB_CPU=y
# CONFIG_SCHEDSTATS=y


# Tracing
CONFIG_KALLSYMS_ALL=y
CONFIG_KPROBES=y
CONFIG_FTRACE=y
CONFIG_FPROBE=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_FUNCTION_ERROR_INJECTION=y   # function overriding

