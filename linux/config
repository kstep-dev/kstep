#
# Basic
#

# 64-bit kernel
CONFIG_64BIT=y
# initramfs support
CONFIG_BLK_DEV_INITRD=y
# run elf binaries
CONFIG_BINFMT_ELF=y
# load kernel modules
CONFIG_MODULES=y
# virtualization
CONFIG_HYPERVISOR_GUEST=y
# paravirtualization
CONFIG_PARAVIRT=y
# for kvm_sched_clock_read
CONFIG_KVM_GUEST=y
# debug kernel
CONFIG_DEBUG_KERNEL=y
# enable expert mode
CONFIG_EXPERT=y
# BUG/WARN support
CONFIG_BUG=y

#
# Output
#

# TTY support
CONFIG_TTY=y
# 8250 serial port support
CONFIG_SERIAL_8250=y
# Console on serial port
CONFIG_SERIAL_8250_CONSOLE=y
# printk support
CONFIG_PRINTK=y
# printk with timestamp
CONFIG_PRINTK_TIME=y

#
# File systems
#

# /proc
CONFIG_PROC_FS=y
# /sys
CONFIG_SYSFS=y
# /sys/kernel/debug
CONFIG_DEBUG_FS=y
# /dev
CONFIG_DEVTMPFS=y

#
# CPU and power management
#

# SMP support
CONFIG_SMP=y
# NUMA support
CONFIG_NUMA=y
# ACPI support
CONFIG_ACPI=y
# ACPI processor support
CONFIG_ACPI_PROCESSOR=y
# ACPI CPU hotplug support
CONFIG_ACPI_HOTPLUG_CPU=y
# Frequency scaling
CONFIG_CPU_FREQ=y
# CPU hotplug support
CONFIG_HOTPLUG_CPU=y
# PM sleep support
CONFIG_PM_SLEEP=y
# PM sleep SMP support
CONFIG_PM_SLEEP_SMP=y
# Suspend support
CONFIG_SUSPEND=y
# Freezer support
CONFIG_FREEZER=y

#
# Scheduler
#

# Core scheduler and sched classes
CONFIG_SCHED_CORE=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y
CONFIG_RT_GROUP_SCHED=y
# Topology
CONFIG_SCHED_SMT=y
CONFIG_SCHED_CLUSTER=y
CONFIG_SCHED_MC=y
# cgroup
CONFIG_CGROUPS=y
CONFIG_CGROUP_SCHED=y
CONFIG_CPUSETS=y
# High resolution timers
CONFIG_HIGH_RES_TIMERS=y
# tl->name
CONFIG_SCHED_DEBUG=y
CONFIG_HZ_1000=y
# CONFIG_NO_HZ_IDLE is not set
# CONFIG_NO_HZ_FULL is not set
# CONFIG_NO_HZ is not set

#
# Tracing
#
CONFIG_KALLSYMS_ALL=y
CONFIG_KPROBES=y
CONFIG_FTRACE=y
CONFIG_FPROBE=y
CONFIG_DYNAMIC_FTRACE=y
CONFIG_FUNCTION_TRACER=y
# function overriding
CONFIG_FUNCTION_ERROR_INJECTION=y

# Debugging
# CONFIG_DEBUG_INFO_DWARF5=y
# CONFIG_GDB_SCRIPTS=y
