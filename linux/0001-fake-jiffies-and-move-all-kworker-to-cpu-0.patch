From 1ae9cc4d812c1b21a277e667b055795481b8c221 Mon Sep 17 00:00:00 2001
From: Tingjia-0v0 <tjcao980311@gmail.com>
Date: Tue, 28 Oct 2025 02:50:01 -0500
Subject: [PATCH] fake jiffies and move all kworker to cpu 0

---
 kernel/sched/clock.c    |  3 +--
 kernel/sched/sched.h    |  2 ++
 kernel/sched/wait_bit.c |  2 +-
 kernel/workqueue.c      | 40 +++++++++++++++++++++-------------------
 4 files changed, 25 insertions(+), 22 deletions(-)

diff --git a/kernel/sched/clock.c b/kernel/sched/clock.c
index f5e6dd6a6b3a..cf02ed970134 100644
--- a/kernel/sched/clock.c
+++ b/kernel/sched/clock.c
@@ -64,8 +64,7 @@
  */
 notrace unsigned long long __weak sched_clock(void)
 {
-	return (unsigned long long)(jiffies - INITIAL_JIFFIES)
-					* (NSEC_PER_SEC / HZ);
+	return 0;
 }
 EXPORT_SYMBOL_GPL(sched_clock);
 
diff --git a/kernel/sched/sched.h b/kernel/sched/sched.h
index 1f5d07067f60..62f9403e4052 100644
--- a/kernel/sched/sched.h
+++ b/kernel/sched/sched.h
@@ -2007,6 +2007,8 @@ queue_balance_callback(struct rq *rq,
 	for (__sd = rcu_dereference_check_sched_domain(cpu_rq(cpu)->sd); \
 			__sd; __sd = __sd->parent)
 
+#define jiffies INITIAL_JIFFIES + nsecs_to_jiffies(sched_clock())
+
 /* A mask of all the SD flags that have the SDF_SHARED_CHILD metaflag */
 #define SD_FLAG(name, mflags) (name * !!((mflags) & SDF_SHARED_CHILD)) |
 static const unsigned int SD_SHARED_CHILD_MASK =
diff --git a/kernel/sched/wait_bit.c b/kernel/sched/wait_bit.c
index 1088d3b7012c..b50881e1d8a5 100644
--- a/kernel/sched/wait_bit.c
+++ b/kernel/sched/wait_bit.c
@@ -257,7 +257,7 @@ EXPORT_SYMBOL(bit_wait_io);
 
 __sched int bit_wait_timeout(struct wait_bit_key *word, int mode)
 {
-	unsigned long now = READ_ONCE(jiffies);
+	unsigned long now = jiffies;
 
 	if (time_after_eq(now, word->timeout))
 		return -EAGAIN;
diff --git a/kernel/workqueue.c b/kernel/workqueue.c
index 45320e27a16c..f1e4de59c9d6 100644
--- a/kernel/workqueue.c
+++ b/kernel/workqueue.c
@@ -25,6 +25,7 @@
  * Please read Documentation/core-api/workqueue.rst for details.
  */
 
+#include "linux/numa.h"
 #include <linux/export.h>
 #include <linux/kernel.h>
 #include <linux/sched.h>
@@ -2655,13 +2656,13 @@ static struct worker *alloc_worker(int node)
 	return worker;
 }
 
-static cpumask_t *pool_allowed_cpus(struct worker_pool *pool)
-{
-	if (pool->cpu < 0 && pool->attrs->affn_strict)
-		return pool->attrs->__pod_cpumask;
-	else
-		return pool->attrs->cpumask;
-}
+// static cpumask_t *pool_allowed_cpus(struct worker_pool *pool)
+// {
+// 	if (pool->cpu < 0 && pool->attrs->affn_strict)
+// 		return pool->attrs->__pod_cpumask;
+// 	else
+// 		return pool->attrs->cpumask;
+// }
 
 /**
  * worker_attach_to_pool() - attach a worker to a pool
@@ -2690,7 +2691,8 @@ static void worker_attach_to_pool(struct worker *worker,
 	}
 
 	if (worker->rescue_wq)
-		set_cpus_allowed_ptr(worker->task, pool_allowed_cpus(pool));
+		// set_cpus_allowed_ptr(worker->task, pool_allowed_cpus(pool));
+		set_cpus_allowed_ptr(worker->task, cpumask_of(0));
 
 	list_add_tail(&worker->node, &pool->workers);
 	worker->pool = pool;
@@ -2704,9 +2706,9 @@ static void unbind_worker(struct worker *worker)
 
 	kthread_set_per_cpu(worker->task, -1);
 	if (cpumask_intersects(wq_unbound_cpumask, cpu_active_mask))
-		WARN_ON_ONCE(set_cpus_allowed_ptr(worker->task, wq_unbound_cpumask) < 0);
+		WARN_ON_ONCE(set_cpus_allowed_ptr(worker->task, cpumask_of(0)) < 0);
 	else
-		WARN_ON_ONCE(set_cpus_allowed_ptr(worker->task, cpu_possible_mask) < 0);
+		WARN_ON_ONCE(set_cpus_allowed_ptr(worker->task, cpumask_of(0)) < 0);
 }
 
 
@@ -2800,7 +2802,7 @@ static struct worker *create_worker(struct worker_pool *pool)
 
 		format_worker_id(id_buf, sizeof(id_buf), worker, pool);
 		worker->task = kthread_create_on_node(worker_thread, worker,
-						      pool->node, "%s", id_buf);
+			NUMA_NO_NODE, "%s", id_buf);
 		if (IS_ERR(worker->task)) {
 			if (PTR_ERR(worker->task) == -EINTR) {
 				pr_err("workqueue: Interrupted when creating a worker thread \"%s\"\n",
@@ -2813,7 +2815,7 @@ static struct worker *create_worker(struct worker_pool *pool)
 		}
 
 		set_user_nice(worker->task, pool->attrs->nice);
-		kthread_bind_mask(worker->task, pool_allowed_cpus(pool));
+		kthread_bind_mask(worker->task, cpumask_of(0));
 	}
 
 	/* successful, attach the worker to the pool */
@@ -5379,7 +5381,7 @@ static void apply_wqattrs_commit(struct apply_wqattrs_ctx *ctx)
 	/* rescuer needs to respect wq cpumask changes */
 	if (ctx->wq->rescuer)
 		set_cpus_allowed_ptr(ctx->wq->rescuer->task,
-				     unbound_effective_cpumask(ctx->wq));
+				     cpumask_of(0));
 
 	mutex_unlock(&ctx->wq->mutex);
 }
@@ -5614,10 +5616,10 @@ static int init_rescuer(struct workqueue_struct *wq)
 	}
 
 	wq->rescuer = rescuer;
-	if (wq->flags & WQ_UNBOUND)
-		kthread_bind_mask(rescuer->task, unbound_effective_cpumask(wq));
-	else
-		kthread_bind_mask(rescuer->task, cpu_possible_mask);
+	// if (wq->flags & WQ_UNBOUND)
+	// 	kthread_bind_mask(rescuer->task, unbound_effective_cpumask(wq));
+	// else
+	kthread_bind(rescuer->task, 0);
 	wake_up_process(rescuer->task);
 
 	return 0;
@@ -6606,7 +6608,7 @@ static void rebind_workers(struct worker_pool *pool)
 	for_each_pool_worker(worker, pool) {
 		kthread_set_per_cpu(worker->task, pool->cpu);
 		WARN_ON_ONCE(set_cpus_allowed_ptr(worker->task,
-						  pool_allowed_cpus(pool)) < 0);
+						  cpumask_of(0)) < 0);
 	}
 
 	raw_spin_lock_irq(&pool->lock);
@@ -6665,7 +6667,7 @@ static void restore_unbound_workers_cpumask(struct worker_pool *pool, int cpu)
 
 	/* as we're called from CPU_ONLINE, the following shouldn't fail */
 	for_each_pool_worker(worker, pool)
-		WARN_ON_ONCE(set_cpus_allowed_ptr(worker->task, &cpumask) < 0);
+		WARN_ON_ONCE(set_cpus_allowed_ptr(worker->task, cpumask_of(0)) < 0);
 }
 
 int workqueue_prepare_cpu(unsigned int cpu)
-- 
2.43.0

