From 0b31423db9fd9b079c429326c349bd25a7924638 Mon Sep 17 00:00:00 2001
From: Tingjia-0v0 <tjcao980311@gmail.com>
Date: Mon, 3 Nov 2025 20:51:31 -0600
Subject: [PATCH] enable fake jiffies in sched subsystem

---
 kernel/sched/clock.c    | 3 +--
 kernel/sched/fair.c     | 3 ++-
 kernel/sched/sched.h    | 2 ++
 kernel/sched/wait_bit.c | 2 +-
 4 files changed, 6 insertions(+), 4 deletions(-)

diff --git a/kernel/sched/clock.c b/kernel/sched/clock.c
index a09655b48140..82e8ca894868 100644
--- a/kernel/sched/clock.c
+++ b/kernel/sched/clock.c
@@ -61,8 +61,7 @@
  */
 notrace unsigned long long __weak sched_clock(void)
 {
-	return (unsigned long long)(jiffies - INITIAL_JIFFIES)
-					* (NSEC_PER_SEC / HZ);
+	return 0;
 }
 EXPORT_SYMBOL_GPL(sched_clock);
 
diff --git a/kernel/sched/fair.c b/kernel/sched/fair.c
index c798d2795243..ab939e4957c5 100644
--- a/kernel/sched/fair.c
+++ b/kernel/sched/fair.c
@@ -103,6 +103,7 @@ int __weak arch_asym_cpu_priority(int cpu)
  * (default: ~20%)
  */
 #define fits_capacity(cap, max)	((cap) * 1280 < (max) * 1024)
+#define INITIAL_JIFFIES ((unsigned long)(unsigned int) (-300*HZ))
 
 /*
  * The margin used when comparing CPU capacities.
@@ -13291,7 +13292,7 @@ static void set_next_task_fair(struct rq *rq, struct task_struct *p, bool first)
 void init_cfs_rq(struct cfs_rq *cfs_rq)
 {
 	cfs_rq->tasks_timeline = RB_ROOT_CACHED;
-	cfs_rq->min_vruntime = (u64)(-(1LL << 20));
+	cfs_rq->min_vruntime = 10000000000;
 #ifdef CONFIG_SMP
 	raw_spin_lock_init(&cfs_rq->removed.lock);
 #endif
diff --git a/kernel/sched/sched.h b/kernel/sched/sched.h
index 023b844159c9..1fe49c224252 100644
--- a/kernel/sched/sched.h
+++ b/kernel/sched/sched.h
@@ -1993,6 +1993,8 @@ queue_balance_callback(struct rq *rq,
 	for (__sd = rcu_dereference_check_sched_domain(cpu_rq(cpu)->sd); \
 			__sd; __sd = __sd->parent)
 
+#define jiffies INITIAL_JIFFIES + nsecs_to_jiffies(sched_clock())
+
 /* A mask of all the SD flags that have the SDF_SHARED_CHILD metaflag */
 #define SD_FLAG(name, mflags) (name * !!((mflags) & SDF_SHARED_CHILD)) |
 static const unsigned int SD_SHARED_CHILD_MASK =
diff --git a/kernel/sched/wait_bit.c b/kernel/sched/wait_bit.c
index b410b61cec95..0da9f257fbc2 100644
--- a/kernel/sched/wait_bit.c
+++ b/kernel/sched/wait_bit.c
@@ -254,7 +254,7 @@ EXPORT_SYMBOL(bit_wait_io);
 
 __sched int bit_wait_timeout(struct wait_bit_key *word, int mode)
 {
-	unsigned long now = READ_ONCE(jiffies);
+	unsigned long now = jiffies;
 
 	if (time_after_eq(now, word->timeout))
 		return -EAGAIN;
-- 
2.43.0

