{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "UML",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/linux/current/linux",
            "args": [
                "ubd0=rootfs/img.ext4",
                "root=/dev/ubda",
                "mem=256M"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "rootfs"
        }
    ]
}
